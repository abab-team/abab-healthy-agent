# Copy this file to .env.production on the server. Do not commit the copied file.
ENV=production
DEBUG=false

# This is the HTTPS domain used by the mobile production build.
SERVER_NAME=api.example.com
CORS_ORIGINS=https://app.example.com

AUTH_ENABLED=true
AUTH_DEMO_LOGIN_ENABLED=false
AUTH_DEMO_HEADER_ENABLED=false
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
JWT_SECRET_KEY=replace-with-a-different-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Use a unique database password; do not reuse either application secret.
POSTGRES_DB=family_health
POSTGRES_USER=family_health
POSTGRES_PASSWORD=replace-with-a-long-unique-database-password

# Existing implementation supports local persistent document/avatar storage only.
LOCAL_STORAGE_DIR=/var/lib/family-health/storage/local
DOCUMENT_UPLOAD_ENABLED=true
DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_STORAGE_DIR=/var/lib/family-health/storage/documents
DOCUMENT_MAX_UPLOAD_MB=10
DOCUMENT_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg

# Production keeps optional raw-data and external-knowledge features disabled.
OCR_ENABLED=false
OCR_STORE_RAW_TEXT=false
RAG_ENABLED=false
RAG_STORE_RAW_TEXT=false
RAG_ALLOW_EXTERNAL_KNOWLEDGE=false

# Configure a real provider only after its API key is placed in this server-only file.
LLM_ENABLED=false
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=mock-model
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2
DAILY_BRIEF_USE_LLM=false
LLM_PLANNER_ENABLED=false
LLM_ANSWER_COMPOSER_ENABLED=false
LLM_CHAT_ENABLED=true
LLM_CRITIC_ENABLED=false
