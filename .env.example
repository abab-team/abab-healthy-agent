# =========================================================
# Abab Healthy Agent 环境变量模板
# 说明：
# - 本文件只提供本地开发和部署时需要的配置项示例。
# - 真实运行时通常复制为 .env，并在 .env 中填写真实密钥。
# - 不要把真实 SECRET_KEY、数据库密码、对象存储密钥、LLM API Key 提交到仓库。
# =========================================================

# -------------------------
# 应用基础配置
# -------------------------
# 应用名称：用于日志、健康检查响应、服务标识等场景。
APP_NAME=family-health-agent

# 运行环境：development/testing/production。
# 业务代码可以根据环境切换日志级别、调试模式和安全策略。
ENV=development

# 调试开关：开发环境可开启，生产环境必须关闭，避免暴露异常堆栈和敏感路径。
DEBUG=true

# -------------------------
# 数据库与缓存
# -------------------------
# PostgreSQL 连接地址。
# 本机直接运行后端时可使用 localhost；如果后端在 Docker 容器内运行，主机名通常要改成 compose 服务名。
DATABASE_URL=postgresql+psycopg://family_health:family_health@localhost:5432/family_health

# Redis 连接地址：用于缓存、后台任务队列或临时状态。
# 与数据库一样，容器内访问时要确认主机名是否与 docker-compose 服务名一致。
REDIS_URL=redis://localhost:6379/0

# -------------------------
# 认证与安全
# -------------------------
# 后端签名密钥：通常用于 JWT、会话签名等安全场景。
# 这里只是示例值，真实环境必须替换为强随机字符串。
SECRET_KEY=change-me-in-local-env

# Access Token 过期时间，单位分钟。
# 当前表示登录令牌 60 分钟后过期。
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS 白名单：允许哪些前端源访问后端接口，多个地址用英文逗号分隔。
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -------------------------
# LLM / Agent
# -------------------------
# LLM 默认关闭；Phase 10.A 只提供底层 client，不接业务 workflow。
LLM_ENABLED=false

# LLM 提供商：mock 表示不调用真实模型，适合先跑通业务流程和工具调用链路。
LLM_PROVIDER=mock

# OpenAI-compatible endpoint。真实地址只写入本地 .env。
LLM_BASE_URL=

# OpenAI-compatible API Key：示例文件保持为空，真实密钥只写入本地 .env。
LLM_API_KEY=

# OpenAI-compatible 模型名。mock 模式不需要真实模型。
LLM_MODEL=mock-model

# LLM 请求超时、生成长度与温度。后续业务接入时仍必须经过 Safety Policy。
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

# daily_health_brief 可选 LLM 开关。必须同时满足 LLM_ENABLED=true 才会尝试调用 LLM。
DAILY_BRIEF_USE_LLM=false

# 兼容旧配置名，Phase 10.A LLM client 不读取该字段。
OPENAI_API_KEY=

# -------------------------
# 文件存储与对象存储
# -------------------------
# 本地文件目录：开发阶段可保存上传资料、导出报告和临时文件。
LOCAL_STORAGE_DIR=backend/storage/local

# S3 兼容对象存储地址：本地开发通常使用 MinIO。
S3_ENDPOINT=http://localhost:9000

# 对象存储桶名：用于归档体检报告、医疗资料、导出文件等。
S3_BUCKET=family-health

# 对象存储访问账号：开发环境可使用 MinIO 默认值，生产环境必须更换。
S3_ACCESS_KEY=minioadmin

# 对象存储访问密钥：开发环境可使用 MinIO 默认值，生产环境必须更换。
S3_SECRET_KEY=minioadmin

# -------------------------
# Docker Compose 初始化配置
# -------------------------
# PostgreSQL 初始化数据库名，需要与 DATABASE_URL 中的数据库名保持一致。
POSTGRES_DB=family_health

# PostgreSQL 初始化用户名，需要与 DATABASE_URL 中的用户名保持一致。
POSTGRES_USER=family_health

# PostgreSQL 初始化密码，开发环境可简单，生产环境必须使用强密码。
POSTGRES_PASSWORD=family_health

# MinIO root 用户名，开发环境默认值，生产环境必须更换。
MINIO_ROOT_USER=minioadmin

# MinIO root 密码，开发环境默认值，生产环境必须更换。
MINIO_ROOT_PASSWORD=minioadmin

# -------------------------
# 健康报告
# -------------------------
# 每日健康报告生成小时，通常由定时任务读取。
DAILY_REPORT_HOUR=8
