# =========================================================
# Abab Healthy Agent 环境变量模板
# 说明：
# - 本文件只提供本地开发和部署时需要的配置项示例。
# - 真实运行时通常复制为 .env，并在 .env 中填写真实密钥。
# - 不要把真实 SECRET_KEY、数据库密码、对象存储密钥、LLM API Key 提交到仓库。
# =========================================================

# -------------------------
# 应用基础配置
# -------------------------
# 应用名称：用于日志、健康检查响应、服务标识等场景。
APP_NAME=family-health-agent

# 运行环境：development/testing/production。
# 业务代码可以根据环境切换日志级别、调试模式和安全策略。
ENV=development

# Deployment documentation alias. Backend code currently reads ENV; keep APP_ENV
# aligned in deployment environments for operators who expect APP_ENV naming.
APP_ENV=development

# Phase 26 production readiness check:
#   python tools/check_production_readiness.py --env-file .env
# Production-like deployments must use ENV=production, DEBUG=false,
# AUTH_ENABLED=true, AUTH_DEMO_HEADER_ENABLED=false, strong random secrets,
# PostgreSQL, explicit HTTPS CORS origins, and no committed .env file.

# 调试开关：开发环境可开启，生产环境必须关闭，避免暴露异常堆栈和敏感路径。
DEBUG=true

# -------------------------
# 数据库与缓存
# -------------------------
# PostgreSQL 连接地址。
# 本机直接运行后端时可使用 localhost；如果后端在 Docker 容器内运行，主机名通常要改成 compose 服务名。
DATABASE_URL=postgresql+psycopg://family_health:family_health@localhost:5432/family_health

# Redis 连接地址：用于缓存、后台任务队列或临时状态。
# 与数据库一样，容器内访问时要确认主机名是否与 docker-compose 服务名一致。
REDIS_URL=redis://localhost:6379/0

# -------------------------
# 认证与安全
# -------------------------
# 后端签名密钥：通常用于 JWT、会话签名等安全场景。
# 这里只是示例值，真实环境必须替换为强随机字符串。
SECRET_KEY=change-me-in-local-env

# Auth/JWT。开发默认保留 demo header；生产或外部试用必须关闭 AUTH_DEMO_HEADER_ENABLED。
AUTH_ENABLED=false
AUTH_DEMO_LOGIN_ENABLED=true
AUTH_DEMO_HEADER_ENABLED=true
JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256

# Access Token 过期时间，单位分钟。
# 当前表示登录令牌 15 分钟后过期。
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS 白名单：允许哪些前端源访问后端接口，多个地址用英文逗号分隔。
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Alias used in deployment docs. Backend code currently reads CORS_ORIGINS.
# Keep this value aligned with CORS_ORIGINS if your deployment platform uses
# CORS_ALLOW_ORIGINS naming.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -------------------------
# LLM / Agent
# -------------------------
# LLM 默认关闭；Phase 10.A 只提供底层 client，不接业务 workflow。
LLM_ENABLED=false

# LLM 提供商：mock 表示不调用真实模型，适合先跑通业务流程和工具调用链路。
LLM_PROVIDER=mock

# OpenAI-compatible endpoint。真实地址只写入本地 .env。
LLM_BASE_URL=

# OpenAI-compatible API Key：示例文件保持为空，真实密钥只写入本地 .env。
LLM_API_KEY=

# OpenAI-compatible 模型名。mock 模式不需要真实模型。
LLM_MODEL=mock-model

# LLM 请求超时、生成长度与温度。后续业务接入时仍必须经过 Safety Policy。
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

# daily_health_brief 可选 LLM 开关。必须同时满足 LLM_ENABLED=true 才会尝试调用 LLM。
# Phase 10.C：LLM 输出不安全、provider 失败、超时、空输出或 schema 不完整时会 fallback 到规则简报。
DAILY_BRIEF_USE_LLM=false

# Phase 20 prompt registry and LLM-assisted planner. Both LLM planner and
# answer composer stay disabled by default. When enabled, the LLM may only
# return a constrained JSON plan or rewrite a safe summary; backend validation
# still maps tools and runs ToolExecutor.
PROMPT_REGISTRY_ENABLED=true
LLM_PLANNER_ENABLED=false
LLM_ANSWER_COMPOSER_ENABLED=false
RULE_CRITIC_ENABLED=true
LLM_CRITIC_ENABLED=false
LLM_PLANNER_CONFIDENCE_THRESHOLD=0.75

# Phase 14 internal RAG retrieval. Disabled by default. RAG only indexes safe
# summaries from internal records; it does not use external medical knowledge.
RAG_ENABLED=false
RAG_PROVIDER=simple
RAG_INDEX_INTERNAL_SOURCES=true
RAG_ALLOW_EXTERNAL_KNOWLEDGE=false
RAG_MAX_CHUNK_CHARS=1200
RAG_TOP_K=5
RAG_STORE_RAW_TEXT=false
RAG_EMBEDDING_PROVIDER=mock
RAG_RETRIEVAL_PROVIDER=simple
RAG_MIN_SCORE=0.0

# Phase 17 optional LangGraph orchestration. Disabled by default.
# When disabled, workflows keep their deterministic Phase 16 behavior.
LANGGRAPH_ENABLED=false
LANGGRAPH_CHAT_QUERY_ENABLED=false
LANGGRAPH_DAILY_BRIEF_ENABLED=false
LANGGRAPH_FREE_TEXT_RECORD_ENABLED=false
LANGGRAPH_DOCTOR_VISIT_SUMMARY_ENABLED=false
LANGGRAPH_DOCUMENT_EXTRACT_ENABLED=false
LANGGRAPH_DAILY_REPORT_ENABLED=false
LANGGRAPH_HEALTH_KNOWLEDGE_QA_ENABLED=false
LANGGRAPH_ALERT_CREATE_ENABLED=false
LANGGRAPH_SYMPTOM_DRAFT_CREATE_ENABLED=false
LANGGRAPH_MEDICAL_EVENT_DRAFT_CREATE_ENABLED=false
LANGGRAPH_STRICT_MODE=false
LANGGRAPH_TRACE_NODE_SUMMARY=true

# Phase 11 smoke-only switch. Keep false by default.
# Set to true only in a local shell when intentionally running real provider smoke.
LLM_REAL_SMOKE_ENABLED=false

# 兼容旧配置名，Phase 10.A LLM client 不读取该字段。
OPENAI_API_KEY=

# -------------------------
# 文件存储与对象存储
# -------------------------
# 本地文件目录：开发阶段可保存上传资料、导出报告和临时文件。
LOCAL_STORAGE_DIR=backend/storage/local

# Phase 13 document upload foundation. Local storage keeps an internal storage key in DB,
# never an absolute machine path in API responses.
DOCUMENT_UPLOAD_ENABLED=true
DOCUMENT_MAX_UPLOAD_MB=10
DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_STORAGE_DIR=backend/storage/documents
DOCUMENT_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg

# Phase 13 OCR foundation. Disabled by default; mock OCR is deterministic and stores only
# a safe preview unless OCR_STORE_RAW_TEXT is intentionally enabled in a local .env.
OCR_ENABLED=false
OCR_PROVIDER=mock
OCR_TIMEOUT_SECONDS=30
OCR_MAX_TEXT_CHARS=8000
OCR_STORE_RAW_TEXT=false

# S3 兼容对象存储地址：本地开发通常使用 MinIO。
S3_ENDPOINT=http://localhost:9000

# 对象存储桶名：用于归档体检报告、医疗资料、导出文件等。
S3_BUCKET=family-health

# 对象存储访问账号：开发环境可使用 MinIO 默认值，生产环境必须更换。
S3_ACCESS_KEY=minioadmin

# 对象存储访问密钥：开发环境可使用 MinIO 默认值，生产环境必须更换。
S3_SECRET_KEY=minioadmin

# -------------------------
# Docker Compose 初始化配置
# -------------------------
# PostgreSQL 初始化数据库名，需要与 DATABASE_URL 中的数据库名保持一致。
POSTGRES_DB=family_health

# PostgreSQL 初始化用户名，需要与 DATABASE_URL 中的用户名保持一致。
POSTGRES_USER=family_health

# PostgreSQL 初始化密码，开发环境可简单，生产环境必须使用强密码。
POSTGRES_PASSWORD=family_health

# MinIO root 用户名，开发环境默认值，生产环境必须更换。
MINIO_ROOT_USER=minioadmin

# MinIO root 密码，开发环境默认值，生产环境必须更换。
MINIO_ROOT_PASSWORD=minioadmin

# -------------------------
# 健康报告
# -------------------------
# 每日健康报告生成小时，通常由定时任务读取。
DAILY_REPORT_HOUR=8
