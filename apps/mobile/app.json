{
  "expo": {
    "name": "Family Health Agent",
    "slug": "family-health-agent-mobile",
    "scheme": "familyhealth",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "927097e3-0625-4421-98cb-2ff2599bff82"
      }
    },
    "owner": "bready1222"
  }
}
